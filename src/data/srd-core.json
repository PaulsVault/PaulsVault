    {"id":"condition:blinded","type":"condition","name":"Blinded","data":{"summary":"No puedes ver; fallas automáticamente pruebas que requieran vista. Tus ataques tienen desventaja; los ataques contra ti tienen ventaja."}},
    {"id":"condition:charmed","type":"condition","name":"Charmed","data":{"summary":"No puedes atacar al hechicero ni elegirlo como objetivo de efectos dañinos. El hechicero tiene ventaja en pruebas sociales contra ti."}},
    {"id":"condition:deafened","type":"condition","name":"Deafened","data":{"summary":"No puedes oír; fallas automáticamente pruebas que requieran oído."}},
    {"id":"condition:exhaustion","type":"condition","name":"Exhaustion","data":{"summary":"Acumulable (niveles 1-6). Por cada nivel: -2 a todas las tiradas de d20 y -5 ft de velocidad. A nivel 6, mueres. Un descanso largo elimina 1 nivel.","levels":6}},
    {"id":"condition:frightened","type":"condition","name":"Frightened","data":{"summary":"Desventaja en pruebas de característica y ataques mientras veas la fuente del miedo; no puedes acercarte voluntariamente a ella."}},
    {"id":"condition:grappled","type":"condition","name":"Grappled","data":{"summary":"Velocidad 0. Desventaja en ataques contra cualquiera que no sea quien te agarra. Quien te agarra puede arrastrarte moviéndose (a velocidad media, salvo que seas más pequeño)."}},
    {"id":"condition:incapacitated","type":"condition","name":"Incapacitated","data":{"summary":"No puedes realizar acciones, acciones adicionales ni reacciones. Se rompe tu concentración. No puedes hablar. Si eres sorprendido, desventaja en iniciativa."}},
    {"id":"condition:invisible","type":"condition","name":"Invisible","data":{"summary":"Ventaja en iniciativa. No puedes ser visto sin magia o sentidos especiales (cuentas como muy oscurecido). Tus ataques tienen ventaja; los ataques contra ti tienen desventaja."}},
    {"id":"condition:paralyzed","type":"condition","name":"Paralyzed","data":{"summary":"Incapacitado; velocidad 0. Fallas automáticamente salvaciones de FUE y DES. Los ataques contra ti tienen ventaja; todo impacto a 5 ft es crítico."}},
    {"id":"condition:petrified","type":"condition","name":"Petrified","data":{"summary":"Transformado en sustancia sólida; incapacitado, velocidad 0. Resistencia a todo daño; inmune a veneno y a Poisoned. Fallas salvaciones de FUE y DES; ataques contra ti con ventaja."}},
    {"id":"condition:poisoned","type":"condition","name":"Poisoned","data":{"summary":"Desventaja en tiradas de ataque y pruebas de característica."}},
    {"id":"condition:prone","type":"condition","name":"Prone","data":{"summary":"Solo puedes arrastrarte o gastar movimiento para levantarte. Desventaja en tus ataques. Ataques contra ti: ventaja a 5 ft, desventaja a más distancia."}},
    {"id":"condition:restrained","type":"condition","name":"Restrained","data":{"summary":"Velocidad 0. Tus ataques con desventaja; ataques contra ti con ventaja. Desventaja en salvaciones de DES."}},
    {"id":"condition:stunned","type":"condition","name":"Stunned","data":{"summary":"Incapacitado. Fallas automáticamente salvaciones de FUE y DES. Ataques contra ti con ventaja."}},
    {"id":"condition:unconscious","type":"condition","name":"Unconscious","data":{"summary":"Incapacitado, no puedes moverte, sueltas lo que sostienes, caes Prone. Fallas salvaciones de FUE y DES. Ataques contra ti con ventaja; impactos a 5 ft son críticos."}},
