# Copia este archivo a `.env` (gitignored) y completa tus valores reales.
# NO subas `.env` a git ni pegues estos secretos en ningún chat.

# ─── Base de datos Turso (producción) ───
# Sácalos de tu proyecto en Turso, o de Vercel → Settings → Environment Variables.
# Con esto, `node scripts/import-packs.mjs` sube los packs a tu Turso de producción.
TURSO_DATABASE_URL=libsql://tu-base.turso.io
TURSO_AUTH_TOKEN=tu-token-secreto-de-turso

# ─── Sesiones ───
# Debe ser el MISMO valor que tienes en Vercel (si difiere, las sesiones no valen).
SESSION_SECRET=cadena-larga-aleatoria-de-64-hex

# ─── Registro por invitación ───
# Email(es) admin que pueden generar invitaciones (coma-separado).
ADMIN_EMAILS=tu-email@ejemplo.com
