# Reemplaza tu-dominio.com por tu dominio real (apuntando a la IP pública de la VM).
# Caddy saca y renueva el certificado HTTPS automáticamente (Let's Encrypt).
tu-dominio.com {
    encode gzip
    reverse_proxy app:3000
}

